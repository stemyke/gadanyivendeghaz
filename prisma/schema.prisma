datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullname  String
  email     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
